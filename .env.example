# Copy this file to .env at the repo root and fill in real values.
# .env is gitignored — credentials never leave your machine.
#
# Read by dataset_tools/cityscapes/run.sh when called with --download.
# Register at https://www.cityscapes-dataset.com/ to obtain credentials.

CITYSCAPES_USERNAME=your-registered-email@example.com
CITYSCAPES_PASSWORD=your-password
